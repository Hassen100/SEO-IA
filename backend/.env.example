# Variables d'environnement pour le dashboard SEO/IA
# Copiez ce fichier en .env et remplacez les valeurs

# Chemin vers le fichier JSON du compte de service Google
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ID de la propriété Google Analytics 4
# Format: properties/XXXXXXXXXXXX
GA4_PROPERTY_ID=properties/35RSYRP4HD

# URL du site dans Google Search Console
GSC_SITE_URL=https://seo-ia123.vercel.app

# Configuration Flask
FLASK_ENV=development
FLASK_DEBUG=1
PORT=5000

# Configuration du cache (en secondes)
CACHE_TIMEOUT=300
